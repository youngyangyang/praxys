data/garmin/
data/stryd/
data/oura/
data/ai/

# Generated outputs
analysis/dashboard.html
analysis/reports/

# SQLite database (and WAL-mode sidecars created at runtime)
data/trainsight.db
*.db-journal
*.db-wal
*.db-shm

# Test artifacts
test-screenshots/

# Python
__pycache__/
*.pyc
.venv/
.env
.garmin_tokens/
.pytest_cache/

# Build version stamp written by deploy-backend.yml — read by
# api.version.get_api_version(). Source of truth is the workflow,
# never the working tree.
api/_build_version.txt

# Node
web/node_modules/
web/dist/

# IDE / tool caches
.claude/*
!.claude/commands/
!.claude/commands/**
!.claude/settings.json
!.claude/agents/
!.claude/agents/**
!.claude/skills/
!.claude/skills/**
!.claude/hooks/
!.claude/hooks/**
.playwright-mcp/

# Git worktrees
.worktrees/

# Superpowers tooling artifacts
.superpowers/
docs/superpowers/

# Screenshots (ad-hoc QA captures — committed screenshots live under
# data/screenshots/ and docs/marketing/screenshots/)
web/screenshot-*.png
/screenshot-*.png

# Performance baselines: keep ONLY the hand-curated README.md per
# baseline directory. HARs and all sitespeed.io output stay out of the
# repo — the public-repo move (2026-04-26) made HAR contents reachable
# to anyone (including stale auth tokens), so HARs now live in two
# places only:
#   - GH Actions artifacts (30-day retention; fine for recent reviews)
#   - Azure blob container `perfbaselines-archive` on stperftrainsight
#     (private, durable; see docs/perf-baselines/ci-setup.md for
#     retrieval).
# A pre-public-archive bundle of the HARs that used to live here is at
# perfbaselines-HARs-pre-public-2026-04-26.tar.gz in that container.
docs/perf-baselines/**/*.har
docs/perf-baselines/**/data/video/
docs/perf-baselines/**/data/filmstrip/
docs/perf-baselines/**/data/screenshots/
docs/perf-baselines/**/*.html
docs/perf-baselines/**/*.ico
docs/perf-baselines/*/*/css/
docs/perf-baselines/*/*/js/
docs/perf-baselines/*/*/img/
