<view class="nav-bar {{themeClass}}" style="height: {{totalHeight}}px;">
  <view class="nav-bar__status" style="height: {{statusBarHeight}}px;"></view>
  <view
    class="nav-bar__content"
    style="height: {{contentHeight}}px; padding-right: {{capsuleReservedPx}}px;"
  >
    <view wx:if="{{showBack}}" class="nav-bar__back" bindtap="onBackTap">‹</view>
    <view wx:if="{{showWordmark}}" class="nav-bar__wordmark">
      <image class="nav-bar__logo" src="/assets/brand/mark.png" mode="aspectFit" />
      <text class="nav-bar__brand">Pra<text class="nav-bar__brand-accent">x</text>ys</text>
    </view>
    <text wx:else class="nav-bar__title">{{title}}</text>

    <!-- Optional right-side action. Two flavours:
         - rightShare=true  → <button open-type="share"> with share glyph;
                              WeChat handles tap natively (onShareAppMessage).
         - rightText set    → tappable label that triggers `rightaction` event.
         Hidden entirely when neither is set so legacy callers stay unchanged. -->
    <button
      wx:if="{{rightShare}}"
      class="nav-bar__action nav-bar__action--share"
      open-type="share"
      hover-class="nav-bar__action--press"
    >
      <view class="nav-bar__action-icon nav-bar__action-icon--share"></view>
    </button>
    <text
      wx:elif="{{rightText}}"
      class="nav-bar__action nav-bar__action--text"
      hover-class="nav-bar__action--press"
      bindtap="onRightTap"
    >{{rightText}}</text>
  </view>
</view>
