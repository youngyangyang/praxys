{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/block_secrets.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/pytest_on_py.py",
            "timeout": 120,
            "statusMessage": "Running pytest..."
          },
          {
            "type": "command",
            "command": "python .claude/hooks/web_lint.py",
            "timeout": 60,
            "statusMessage": "Linting web file..."
          }
        ]
      }
    ]
  }
}
