# Garmin Connect
GARMIN_EMAIL=your_email@example.com
GARMIN_PASSWORD=your_password
GARMIN_IS_CN=true  # Set to "true" for Garmin Connect China (connect.garmin.cn)

# Stryd
# Option 1 (recommended): email/password for fully automated login
STRYD_EMAIL=your_stryd_email
STRYD_PASSWORD=your_stryd_password
STRYD_USER_ID=your_user_id_from_url_path
# Option 2 (fallback): bearer token from browser DevTools (expires periodically)
STRYD_TOKEN=your_stryd_bearer_token

# Oura (generate at https://cloud.ouraring.com/personal-access-tokens)
OURA_TOKEN=your_oura_personal_access_token

# Dashboard config
REPORT_DAY=Monday
# Goal settings are managed in the app (Settings → Goal), stored in data/config.json

# AI Features (optional — not yet implemented, planned for future)
# ANTHROPIC_API_KEY=your_key_here
